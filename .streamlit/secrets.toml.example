# Copy to secrets.toml and edit (secrets.toml is gitignored — never commit it).
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# Then set your real password.

[auth]
username = "faf"
password = "change-me-now"

# Optional: use a hash instead of plain password
# password_hash = "sha256 hex of your password"
# (generate: python -c "import hashlib; print(hashlib.sha256(b'yourpass').hexdigest())")
