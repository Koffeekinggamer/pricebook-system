# Streamlit Cloud: App → Settings → Secrets → paste the block below.
# Local: copy to secrets.toml (gitignored).
#
# If secrets are missing, the app still accepts built-in defaults:
#   username Foothills / password Amish

[auth]
username = "Foothills"
password = "Amish"

# Optional: monthly Viztech builder price-list sync (scripts/viztech_sync.py)
# [viztech]
# username = "YourViztechUser"
# password = "YourViztechPassword"

# OrderTrac inventory (company account) — used by scripts/ordertrac_*.py
# and Admin → "Sync users from OrderTrac" (creates FAF logins for OT staff).
# [ordertrac]
# username = "you@company.com"
# password = "…"
# base_url = "https://app.ordertracinventory.com"
#
# After secrets are set:
#   1. python scripts/ordertrac_login.py          # captcha / session once
#   2. python scripts/ordertrac_sync_users.py      # create FAF users from OT
#   3. Or Admin tab → Sync users from OrderTrac
